# Azure OpenAI — used by the receipt parser to extract structured data from OCR text
AZURE_OPENAI_KEY=your_azure_openai_key_here
AZURE_OPENAI_ENDPOINT=https://your-resource-name.openai.azure.com/

# The Azure OpenAI deployment name (e.g. gpt-4o, gpt-4.1-mini)
AZURE_OPENAI_DEPLOYMENT=your_deployment_name_here

# Azure Computer Vision — used to extract raw text from receipt images via OCR
AZURE_VISION_KEY=your_azure_vision_key_here
AZURE_VISION_ENDPOINT=https://your-resource-name.cognitiveservices.azure.com/

# Splitwise — used to fetch groups/members and create expenses
SPLITWISE_API_KEY=your_splitwise_api_key_here

# CORS — comma-separated list of frontend origins the API will accept requests from
# Defaults to http://localhost:3000 if not set
ALLOWED_ORIGINS=http://localhost:3000,https://your-frontend.onrender.com

# Frontend — URL of the running backend API (set at Next.js build time)
# For local dev this defaults to http://localhost:8000 and can be omitted
NEXT_PUBLIC_API_URL=http://localhost:8000
